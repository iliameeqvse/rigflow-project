# backend/.env.example — copy to backend/.env and fill in real values.
# This file IS committed to the repo. backend/.env is gitignored.

# ── Landmark vision provider ─────────────────────────────────────────────────
# "none"   → geometry-only detection, no API key needed (safe default for dev).
# "claude" → Claude vision (requires ANTHROPIC_API_KEY below).
LANDMARK_VISION_PROVIDER=none
ANTHROPIC_API_KEY=

# ── Blender ──────────────────────────────────────────────────────────────────
# Leave UNSET when running inside Docker (Dockerfile.celery sets BLENDER_PATH).
# Set to the full path of blender.exe only for a native (non-Docker) Windows install.
# BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 5.0\blender.exe

# ── Django secret key (required) ─────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Keep alphanumeric — a $ character triggers Compose variable interpolation.
SECRET_KEY=change-me-generate-a-real-key

# ── Optional integrations (leave blank to disable) ───────────────────────────
# AWS_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
