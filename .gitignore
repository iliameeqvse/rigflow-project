# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.mo

# ── Django ────────────────────────────────────────────────────────────────────
db.sqlite3
db.sqlite3-journal
*.log
local_settings.py

# collectstatic output — regenerated on every deploy, never commit.
backend/staticfiles/

# Media uploads — never commit user files, generated GLBs, or thumbnails.
backend/media/

# DB dumps / migration backups — keep schema in migrations, not in dumps.
*.sql
*.sql.gz
*.dump
dump.rdb

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.pub
secrets/
*.secret

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
tsconfig.tsbuildinfo
*.tsbuildinfo

# ── Docker volumes / ephemeral ────────────────────────────────────────────────
docker/postgres-data/
docker/redis-data/

# ── OS & editors ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Blender temp files ────────────────────────────────────────────────────────
*.blend1
*.blend2
*.blend@
# Headless ortho render scratch dirs (`/tmp/tmp*` outside the tree is the normal
# location, but in case anyone redirects an output dir into the repo by mistake)
ortho/

# ── Build / runtime artifacts ─────────────────────────────────────────────────
*.bak
*.tmp
tmp/
.history/
*.iml
__MACOSX/

# ── Test / coverage artefacts ─────────────────────────────────────────────────
.tox/
.nox/
coverage.xml
*.cover
